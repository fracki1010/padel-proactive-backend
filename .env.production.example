# Backend (Debian o Railway)
PORT=3000
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/padel-proactive-db
JWT_SECRET=cambia_este_secret_en_produccion
JWT_EXPIRES_IN=365d
GROQ_API_KEY=tu_api_key
# Opcional (recomendado para rotación): lista separada por coma.
# Si se define, se usa en lugar de GROQ_API_KEY.
# GROQ_API_KEYS=tu_api_key_1,tu_api_key_2,tu_api_key_3
# Logs del pool de keys (true/false) y frecuencia de resumen cada N requests
GROQ_KEY_POOL_LOG_ENABLED=true
GROQ_KEY_POOL_LOG_EVERY_REQUESTS=50
GROQ_MODEL=llama-3.3-70b-versatile
IS_DOCKER=false
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Separacion frontend/backend: dominio de Firebase (o varios separados por coma)
# Ejemplo con 2 dominios:
# CORS_ORIGIN=https://tu-app.web.app,https://tu-app.firebaseapp.com
CORS_ORIGIN=https://tu-app.web.app

# Cola de comandos WhatsApp (fase transicion)
WHATSAPP_QUEUE_DRIVER=redis
WHATSAPP_COMMAND_POLL_INTERVAL_MS=2000
WHATSAPP_COMMAND_MAX_ATTEMPTS=3
WHATSAPP_QUEUE_NAME=whatsapp-commands
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TLS=false

# Heartbeat del worker WhatsApp
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_HEARTBEAT_STALE_MS=30000

BACKEND_INTERNAL_TOKEN=
